<?xml version="1.0" encoding="utf-8"?>
<!--
    Debug-only manifest additions.

    The sideload distribution (direct APK from iptv.blanquer.org) is built from
    the `debug` build type and self-updates its own APK, which requires
    REQUEST_INSTALL_PACKAGES on Android 8+. The Google Play release (the
    `release`/bundle build) must NOT declare this permission: updates there go
    through Play, the in-app self-update is gated off, and Play scrutinizes this
    permission. Keeping it debug-only avoids a Play policy review for an unused
    permission.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
</manifest>
